DATABASE_URL=sqlite:///./collective.db

# Auth provider
AUTH_PROVIDER=auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://c0ll3ct1v3-api
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_ALGORITHMS=RS256

# MFA
MFA_REQUIRED=true
MFA_MAX_AGE_SECONDS=900

# Transition controls
ENABLE_LEGACY_PASSWORD_AUTH=false

# CORS (comma-separated; must include every browser origin calling the API)
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://127.0.0.1:3000,http://127.0.0.1:3030



# --- Finance integrations (optional) ---
# APP_ENV=development
FINANCE_INTEGRATIONS_ENABLED=true
FINANCE_DEMO_AUTH=false
FINANCE_MFA_CONSUMER_ENFORCED=false
FINANCE_MFA_STEP_UP_FOR_PLAID_LINK=false
FINANCE_MFA_METHODS_ALLOWED=totp,webauthn
FINANCE_MFA_DEMO_OTP=123456
FINANCE_MFA_ADMIN_ENFORCED=true

PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_WEBHOOK_URL=
PLAID_PRODUCTS=transactions,accounts
PLAID_COUNTRY_CODES=US
PLAID_LINK_MODE=stub

SQUARE_ENV=sandbox
SQUARE_BASE_URL=https://connect.squareupsandbox.com/v2
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=

ENCRYPTION_KEY_ID=
DATA_RETENTION_RAW_WEBHOOK_DAYS=90
DATA_RETENTION_APP_LOG_DAYS=30
DATA_RETENTION_AUDIT_LOG_DAYS=365

# Local CLI accounting DB (not committed)
# FINANCE_DB_PATH=./var/finances.db

# --- Creative media (DigitalOcean Spaces / MinIO) ---
SPACES_ENABLED=false
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_PUBLIC_ENDPOINT=
SPACES_REGION=nyc3
SPACES_BUCKET=pj-media
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
MEDIA_CDN_BASE_URL=
DEFAULT_MEDIA_TENANT_SLUG=phillipjames
PRIMARY_ARTIST_CLAIM_EMAIL_MARKERS=phillip,phillipjames.com
# PRIMARY_ARTIST_CLAIM_AUTH0_SUBS=auth0|your-sub-here
REDIS_URL=

